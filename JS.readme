** WeakRef and FinalizationRegistry.
		const weakref = new WeakRef(object);

		const registry = new FinalizationRegistry((object)=>{
			console.log(`Object Collect GC`,object);
		})
		registry.register(object,"Cleanup Completed");
		object = null;

		object garbaje collect hote hi FinalizationRegistry(callback run karega)



