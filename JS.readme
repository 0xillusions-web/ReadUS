			const date = new Date(Date.now());
			const options = {
				year: "numeric",
				month: "long",
				day: "numeric",
				weekday: "long",
				hour: "numeric",
				timeZone: "UTC"
			}
			console.log(
				//date,
				date.toLocaleDateString("en-US"), = no showes time
				date.toLocaleString("en-IN") = showss time
				date.toLocaleTimeString() = shows only time
			);

