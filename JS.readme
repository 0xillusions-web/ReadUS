** Set.

	inherit maps functions.
	
	console.log(set1.difference(set2)); // set1 me jo difference hai o do 
	console.log(set1.intersection(set2)) // dono me jo same hai o do.

	//console.log(set1.isDisjointFrom(set2)) // dono me koi element match nahi hai to {true}
	console.log(set1.isSupersetOf(set2)) // set2 ke saare values set1 me hai to {true}
	set1.isSubsetOf(set2) // set1 ke saare values set2 me hai ya nahi

	console.log(set1.symmetricDifference(set2)) // dono set ke difference values return in set 
	console.log(set1.union(set2))  // return concat set set1 & set2 

